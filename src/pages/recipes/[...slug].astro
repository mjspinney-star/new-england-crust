---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes', ({ data }) => !data.draft);
  return recipes.map((recipe) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

type Props = { recipe: CollectionEntry<'recipes'> };

const { recipe } = Astro.props;
const { Content } = await recipe.render();

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout
  title={recipe.data.title}
  description={recipe.data.description}
  article={true}
>
  <article class="container-prose py-16 md:py-20">
    <header class="not-prose mb-10 border-b border-timber-300/15 pb-8">
      <p class="text-xs uppercase tracking-[0.2em] text-glow-300">
        {dateFormatter.format(recipe.data.pubDate)}
      </p>
      <h1 class="mt-3 font-display text-4xl leading-tight md:text-5xl">{recipe.data.title}</h1>
      <p class="mt-4 text-lg text-timber-100/90">{recipe.data.description}</p>

      {(recipe.data.prepTime || recipe.data.cookTime || recipe.data.yield) && (
        <dl class="mt-6 flex flex-wrap gap-6 text-sm text-timber-100/80">
          {recipe.data.prepTime && (
            <div>
              <dt class="text-xs uppercase tracking-widest text-timber-300/70">Prep</dt>
              <dd class="mt-0.5">{recipe.data.prepTime}</dd>
            </div>
          )}
          {recipe.data.cookTime && (
            <div>
              <dt class="text-xs uppercase tracking-widest text-timber-300/70">Cook</dt>
              <dd class="mt-0.5">{recipe.data.cookTime}</dd>
            </div>
          )}
          {recipe.data.yield && (
            <div>
              <dt class="text-xs uppercase tracking-widest text-timber-300/70">Yield</dt>
              <dd class="mt-0.5">{recipe.data.yield}</dd>
            </div>
          )}
        </dl>
      )}

      {
        recipe.data.tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {recipe.data.tags.map((tag) => (
              <li class="rounded-full border border-timber-300/20 bg-twilight-600/60 px-3 py-1 text-xs uppercase tracking-wider text-timber-100/90">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div
      class="prose prose-invert max-w-none
             prose-headings:font-display prose-headings:text-timber-50
             prose-a:text-glow-200 hover:prose-a:text-glow-300
             prose-strong:text-glow-200
             prose-blockquote:border-ember-500 prose-blockquote:text-timber-100
             prose-code:text-glow-200 prose-code:before:content-none prose-code:after:content-none
             prose-img:rounded-2xl"
    >
      <Content />
    </div>

    <footer class="mt-16 flex items-center justify-between border-t border-timber-300/15 pt-6 text-sm text-timber-200/80">
      <a href="/recipes/" class="hover:text-glow-200">&larr; All recipes</a>
      <a href="/" class="hover:text-glow-200">Back home</a>
    </footer>
  </article>
</BaseLayout>
