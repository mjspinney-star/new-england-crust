---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import KitPizzaKitForm from '../../components/KitPizzaKitForm.astro';

// Static dough card (lives in /blog/, not the recipes collection)
const doughCard = {
  title: 'The 72-hour cold-ferment dough',
  blurb:
    'Our weekly Friday-night base. Forgiving, flavorful, and built for a hot Ninja or Ooni stone.',
  href: '/blog/72-hour-cold-ferment-dough/',
  eta: '15 min hands-on · 3 days fermenting',
};

// Live recipes from the content collection
const recipeEntries = await getCollection('recipes', ({ data }) => !data.draft);
recipeEntries.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
---

<BaseLayout
  title="Recipes"
  description="Sourdough, sauce, and seasonal toppings — backyard pizza recipes from New England Crust."
>
  <section class="container-page py-16 md:py-20">
    <p class="eyebrow">Recipes</p>
    <h1 class="mt-3 font-display text-4xl text-balance md:text-5xl">Pies worth a Friday night</h1>
    <p class="mt-4 max-w-2xl text-pretty text-timber-100/85">
      Doughs, sauces, and topping combinations we keep coming back to.
      Tested on a Ninja Woodfire and an Ooni out on the deck — pellets,
      gas, and the friends standing around the peel.
    </p>

    <div class="not-prose my-8">
      <KitPizzaKitForm />
    </div>

    <ul class="mt-12 grid gap-6 md:grid-cols-2">
      {/* Dough card — static, lives in /blog/ */}
      <li class="card">
        <a href={doughCard.href} class="block">
          <p class="text-xs uppercase tracking-[0.18em] text-timber-300/80">{doughCard.eta}</p>
          <h2 class="mt-2 font-display text-2xl text-timber-50">{doughCard.title}</h2>
          <p class="mt-3 text-sm text-timber-100/85">{doughCard.blurb}</p>
          <span class="mt-5 inline-flex items-center gap-1 text-sm text-glow-200">
            Read recipe
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
          </span>
        </a>
      </li>

      {/* Collection-driven recipe cards */}
      {
        recipeEntries.map((r) => {
          const eta = r.data.prepTime && r.data.cookTime
            ? `${r.data.prepTime} prep · ${r.data.cookTime} cook`
            : r.data.prepTime || r.data.cookTime || '';
          return (
            <li class="card">
              <a href={`/recipes/${r.slug}/`} class="block">
                <p class="text-xs uppercase tracking-[0.18em] text-timber-300/80">{eta}</p>
                <h2 class="mt-2 font-display text-2xl text-timber-50">{r.data.title}</h2>
                <p class="mt-3 text-sm text-timber-100/85">{r.data.description}</p>
                <span class="mt-5 inline-flex items-center gap-1 text-sm text-glow-200">
                  Read recipe →
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
