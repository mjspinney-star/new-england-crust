---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout
  title="Blog"
  description="Stories, technique notes, and backyard pizza dispatches from New England Crust."
>
  <section class="container-page py-16 md:py-20">
    <p class="eyebrow">The Blog</p>
    <h1 class="mt-3 font-display text-4xl text-balance md:text-5xl">Notes from the deck</h1>
    <p class="mt-4 max-w-2xl text-pretty text-timber-100/85">
      Slow recipes, fast pies, pellet-and-gas opinions, and the occasional
      ingredient pilgrimage. Pull up a chair.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-12 text-timber-200/80">No posts yet — drop a Markdown file in <code class="rounded bg-twilight-600 px-1.5 py-0.5 text-glow-200">src/content/blog/</code> to publish your first.</p>
      ) : (
        <ul class="mt-12 grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <li class="card group">
              <a href={`/blog/${post.slug}/`} class="flex h-full flex-col">
                <div class="flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-timber-300/80">
                  <time datetime={post.data.pubDate.toISOString()}>{dateFormatter.format(post.data.pubDate)}</time>
                  {post.data.tags.length > 0 && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span class="text-glow-300">{post.data.tags[0]}</span>
                    </>
                  )}
                </div>
                <h2 class="mt-3 font-display text-2xl text-timber-50 group-hover:text-glow-200">
                  {post.data.title}
                </h2>
                <p class="mt-3 flex-1 text-sm text-timber-100/85">
                  {post.data.description}
                </p>
                <span class="mt-6 inline-flex items-center gap-1 text-sm text-glow-200">
                  Read more
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" /></svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
