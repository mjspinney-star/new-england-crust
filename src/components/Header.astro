---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/recipes/', label: 'Recipes' },
  { href: '/gear/', label: 'Gear' },
  { href: '/about/', label: 'About' },
];
---

<header class="sticky top-0 z-40 border-b border-timber-300/10 bg-twilight-700/80 backdrop-blur-md">
  <div class="container-page flex items-center justify-between py-4">
    <a href="/" class="group flex items-center gap-3" aria-label="New England Crust — home">
      <span
        class="relative grid h-10 w-10 place-items-center rounded-full transition-transform group-hover:scale-105"
        aria-hidden="true"
      >
        <!-- Mark: a small flame inside an ember disc -->
        <span class="absolute inset-0 rounded-full" style="background: radial-gradient(circle at 50% 60%, #ffb247 0%, #d85604 55%, #581b16 100%); box-shadow: 0 0 18px rgba(243,114,7,0.55);"></span>
        <svg viewBox="0 0 24 24" class="relative h-5 w-5 text-twilight-800" fill="currentColor" aria-hidden="true">
          <path d="M12 3c1.2 3.4 4 4 4 8a4 4 0 1 1-8 0c0-2.5 1.6-3.4 2.8-6.4.4-.9.8-1.5 1.2-1.6Z" />
        </svg>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-display text-base font-bold text-timber-50 sm:text-lg">New England Crust</span>
        <span class="text-[10px] font-semibold uppercase tracking-[0.22em] text-glow-300">Backyard pizza · NE</span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'relative rounded-full px-4 py-2 text-sm font-medium transition',
                  isActive(link.href)
                    ? 'text-glow-200'
                    : 'text-timber-100 hover:text-glow-200',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
                {isActive(link.href) && (
                  <span
                    class="pointer-events-none absolute inset-x-3 -bottom-[2px] h-[2px] rounded-full"
                    style="background: linear-gradient(90deg, transparent, #ffb247, transparent);"
                    aria-hidden="true"
                  />
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="/recipes/"
      class="hidden rounded-full bg-ember-500 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-white shadow-ember transition hover:-translate-y-0.5 hover:bg-ember-400 md:inline-flex"
      style="background-image: linear-gradient(135deg, #c63d28 0%, #f37207 100%);"
    >
      Recipes
    </a>

    <details class="relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-full border border-timber-300/30 bg-twilight-600/40 text-timber-50 transition hover:border-glow-300/60 [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </summary>
      <ul class="absolute right-0 mt-2 w-56 overflow-hidden rounded-2xl border border-timber-300/20 bg-twilight-700/95 shadow-deck backdrop-blur-md">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-3 text-sm transition',
                  isActive(link.href)
                    ? 'bg-ember-500/15 text-glow-200'
                    : 'text-timber-100 hover:bg-twilight-600',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </div>
</header>
