---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/recipes/', label: 'Recipes' },
  { href: '/gear/', label: 'Gear' },
  { href: '/about/', label: 'About' },
];
---

<header class="sticky top-0 z-40 border-b border-timber-300/10 bg-twilight-700/80 backdrop-blur-md">
  <div class="container-page flex items-center justify-between py-4">
    <a href="/" class="group flex items-center gap-3" aria-label="New England Crust — home">
      <!-- Badge mark: Ember Amber ring + three-flame group -->
      <svg viewBox="0 0 680 680" width="40" height="40" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
        class="shrink-0 transition-transform group-hover:scale-105"
        style="filter: drop-shadow(0 0 6px rgba(212,131,42,0.3))">
        <circle cx="340" cy="340" r="294" fill="#120E08"/>
        <circle cx="340" cy="340" r="292" fill="none" stroke="#D4832A" stroke-width="8"/>
        <!-- Left flame -->
        <path d="M 298,218 C 308,242 304,266 292,285 C 278,262 278,236 298,218 Z" fill="#C84B2E" opacity="0.85"/>
        <path d="M 298,238 C 306,254 303,270 293,281 C 282,268 282,250 298,238 Z" fill="#E8943A"/>
        <!-- Right flame -->
        <path d="M 362,210 C 374,236 372,260 358,282 C 344,260 344,234 362,210 Z" fill="#C84B2E" opacity="0.85"/>
        <path d="M 362,232 C 371,250 369,268 358,279 C 347,267 347,248 362,232 Z" fill="#E8943A"/>
        <!-- Center flame -->
        <path d="M 340,138 C 368,172 360,230 330,280 C 308,244 312,182 340,138 Z" fill="#C84B2E"/>
        <path d="M 338,162 C 362,194 354,242 328,278 C 310,248 316,196 338,162 Z" fill="#E8943A"/>
        <path d="M 336,190 C 354,216 348,252 328,272 C 314,252 318,218 336,190 Z" fill="#F4C042"/>
        <path d="M 334,215 C 346,232 342,256 328,268 C 318,256 320,234 334,215 Z" fill="#FFEFAA" opacity="0.5"/>
      </svg>
      <span
        class="hidden sm:inline font-display font-bold"
        style="color: #F5EFE0; font-size: 18px; letter-spacing: 2.5px;"
      >New England Crust</span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'relative rounded-full px-4 py-2 text-sm font-medium transition',
                  isActive(link.href)
                    ? 'text-glow-200'
                    : 'text-timber-100 hover:text-glow-200',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
                {isActive(link.href) && (
                  <span
                    class="pointer-events-none absolute inset-x-3 -bottom-[2px] h-[2px] rounded-full"
                    style="background: linear-gradient(90deg, transparent, #ffb247, transparent);"
                    aria-hidden="true"
                  />
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="/recipes/"
      class="hidden rounded-full bg-ember-500 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-white shadow-ember transition hover:-translate-y-0.5 hover:bg-ember-400 md:inline-flex"
      style="background-image: linear-gradient(135deg, #c63d28 0%, #f37207 100%);"
    >
      Recipes
    </a>

    <details class="relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-full border border-timber-300/30 bg-twilight-600/40 text-timber-50 transition hover:border-glow-300/60 [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </summary>
      <ul class="absolute right-0 mt-2 w-56 overflow-hidden rounded-2xl border border-timber-300/20 bg-twilight-700/95 shadow-deck backdrop-blur-md">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-3 text-sm transition',
                  isActive(link.href)
                    ? 'bg-ember-500/15 text-glow-200'
                    : 'text-timber-100 hover:bg-twilight-600',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </div>
</header>
