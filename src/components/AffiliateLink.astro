---
// src/components/AffiliateLink.astro
// Usage in .mdx or .astro files:
//   <AffiliateLink id="ninja-peel" />
//   <AffiliateLink id="ninja-peel" label="grab one here" />
//   <AffiliateLink id="ninja-peel" label="grab one here" badge={false} />

import { getLink } from "../data/affiliateLinks";

interface Props {
  id: string;
  label?: string;   // override link text; defaults to product name
  badge?: boolean;  // show the "→ Amazon" badge; defaults to true
}

const { id, label, badge = true } = Astro.props;
const product = getLink(id);

if (!product) {
  throw new Error(`AffiliateLink: no product found with id "${id}". Check affiliateLinks.ts.`);
}

const linkText = label ?? product.name;
const href = product.short; // use short URL for cleanliness in HTML output
---

<a
  href={href}
  target="_blank"
  rel="noopener nofollow"
  class="affiliate-link"
  data-affiliate="amazon"
  aria-label={`${linkText} (affiliate link, opens Amazon)`}
>{linkText}{badge && <span class="affiliate-badge" aria-hidden="true">→ Amazon</span>}</a>

<style>
  .affiliate-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: currentColor;
    text-underline-offset: 2px;
    white-space: nowrap;
  }

  .affiliate-link:hover {
    opacity: 0.75;
  }

  .affiliate-badge {
    display: inline-block;
    margin-left: 0.35em;
    font-size: 0.72em;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #c45500; /* Amazon orange-ish, adjust to match site palette */
    text-decoration: none;
    vertical-align: middle;
    line-height: 1;
  }
</style>
